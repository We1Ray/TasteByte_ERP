# ============================================================
# TasteByte ERP — Docker Compose Environment Variables
# Copy this file to .env and update the values for your environment.
# ============================================================

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=TastyByte
POSTGRES_PORT=5432

# ── Backend ────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_EXPIRY_HOURS=24
RUST_LOG=info
CORS_ORIGINS=http://localhost:3000
APP_ENV=production

# ── Web Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Nginx ──────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Monitoring (optional) ─────────────────────────────────
SENTRY_DSN=

# ── Database URL (auto-composed from above) ───────────────
# DATABASE_URL is set automatically in docker-compose.yml
# Override here only if using an external database:
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/TastyByte
